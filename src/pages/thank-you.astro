---
import Base from "../layouts/Base.astro";
import "../styles/global.css";
---

<Base title="Thank You – LexBlog Library" description="Your submission to the LexBlog Library has been received and will be reviewed for relevance." currentPage="thank-you">
  <div class="max-w-[760px] mx-auto px-5 md:px-8 pt-[54px] pb-24">
    {/* Success heading */}
    <div class="flex items-center gap-[18px]">
      <span class="w-[46px] h-[46px] rounded-full bg-[#cdeed4] flex items-center justify-center flex-none">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1f8a3b" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 12 10 18 20 6" />
        </svg>
      </span>
      <h1 class="m-0 text-[32px] md:text-[44px] font-[800] tracking-[-0.03em] leading-none text-[#0a0a0b]">Your publishing is in.</h1>
    </div>

    <p class="mt-[26px] text-[20px] leading-[1.55] text-[#3a3d44]">
      We received your submission and will review it for relevance before adding it to the
      Library. You will hear from us at the email you provided.
    </p>

    {/* Author Record upsell card */}
    <div class="mt-[42px] bg-[#0a0a0b] rounded-[14px] p-[40px_28px_44px] md:p-[40px_42px_44px] text-white">
      <div class="flex items-center gap-4 flex-wrap">
        <span class="font-mono text-[13px] font-medium tracking-[0.18em] text-[#9a9da3] uppercase">
          Do more than one piece
        </span>
        <span class="inline-flex items-center text-[14.5px] font-semibold text-[#16181c] bg-[#d7d8da] rounded-[20px] px-[15px] py-[5px]">
          $19/month · $199/year
        </span>
      </div>
      <h2 class="mt-[22px] m-0 text-[26px] md:text-[33px] font-[800] tracking-[-0.025em] leading-[1.12] text-white max-w-[560px]">
        Connect everything you publish, and make it citable.
      </h2>
      <p class="mt-[22px] text-[17.5px] leading-[1.62] text-[#b6b8bd] max-w-[620px] m-0">
        You just added one piece. An Author Record ties your full body of work to one verified
        identity, so your publishing establishes your authority across the legal research platforms
        (HeinOnline, vLex/Clio, and others) and LLMs, and all of it becomes citable.
      </p>
      <div class="mt-8">
        <a href="/author-record" class="inline-flex items-center no-underline bg-white text-[#0a0a0b] text-[16.5px] font-semibold py-[17px] px-[30px] rounded-[8px] hover:bg-[#e8e9ea] transition-colors">
          Get an Author Record — $19/month
        </a>
      </div>
    </div>

    {/* Secondary links */}
    <div class="mt-[34px] flex items-center gap-9">
      <a href="/submit" class="text-[16px] font-medium text-[#16181c] no-underline">Submit another piece</a>
      <a href="/" class="text-[16px] font-medium text-[#16181c] no-underline">Back to the Library</a>
    </div>
  </div>
</Base>
