---
import Base from "../layouts/Base.astro";
import "../styles/global.css";
---

<Base title="Page Not Found – LexBlog Library" description="The page you're looking for doesn't exist or has been moved.">
  <div class="max-w-[1240px] mx-auto px-5 md:px-8 py-24 text-center">
    <div class="font-mono text-[12px] tracking-[0.15em] text-neutral-400 uppercase mb-4">404</div>
    <h1 class="text-[32px] md:text-[42px] font-[800] tracking-[-0.03em] leading-none text-[#0a0a0b] m-0">Page not found</h1>
    <p class="mt-4 text-[17px] text-zinc-500">The page you're looking for doesn't exist or has been moved.</p>
    <div class="mt-8">
      <a href="/" class="inline-flex items-center bg-[#0a0a0b] text-white text-[15px] font-semibold py-[13px] px-7 rounded-[5px] no-underline hover:bg-[#26282d] transition-colors">Back to the Library</a>
    </div>
  </div>
</Base>
