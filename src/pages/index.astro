---
import Base from "../layouts/Base.astro";
import "../styles/global.css";
import { VERSION } from "../lib/version";

const stats = [
  { value: "73,000",    raw: 73000,   label: "Contributing Authors" },
  { value: "1,100,000", raw: 1100000, label: "Published Works" },
  { value: "4,400",     raw: 4400,    label: "Publications" },
];
---

<Base title="The Library at LexBlog" description="Preserving and structuring the insight of legal professionals as citable secondary law." currentPage="home">
  <div class="max-w-[1240px] mx-auto px-5 md:px-8 py-6 pb-20">
    {/* Breadcrumb */}
    <div class="flex items-center gap-[9px] text-[12.5px] text-[#8a8d93] mb-4">
      <a href="https://www.lexblog.com" class="text-[#8a8d93] no-underline">LexBlog</a>
      <span class="text-[#c4c6cb]">/</span>
      <span class="text-[#16181c] font-medium">Library</span>
    </div>

    {/* Title */}
    <div class="pb-[18px] border-b-2 border-[#16181c]">
      <h1 class="m-0 text-[32px] md:text-[46px] font-[800] tracking-[-0.03em] leading-none text-[#0a0a0b]">The Library at LexBlog</h1>
      <div class="mt-[13px] font-mono text-[12.5px] leading-[1.55] tracking-[0.04em] text-[#8a8d93] uppercase">
        Preserving and structuring the insight of legal professionals as citable secondary law
      </div>
    </div>

    {/* Map card */}
    <div class="mt-[34px] border border-[#e7e8ea] rounded-[4px] bg-[#f7f6f2] overflow-hidden">
      <div data-contributor-map data-version={VERSION} class="h-[320px] md:h-[480px]">
        <div data-map-canvas class="w-full h-full bg-[#f4f4f1]" aria-label="Contribution map"></div>
      </div>
    </div>

    {/* Caption */}
    <div class="mt-[13px] font-mono text-[12.5px] leading-[1.55] tracking-[0.04em] text-[#8a8d93] uppercase">
      Each dot represents a contributing publisher. Placement is illustrative, not a precise location.
    </div>

    {/* Stats grid */}
    <div data-stats-grid class="mt-7 grid grid-cols-1 md:grid-cols-3 gap-px bg-[#e7e8ea] border border-[#e7e8ea] rounded-[4px] overflow-hidden">
      {stats.map(s => (
        <div class="bg-white p-[24px_28px]">
          <div data-count-to={s.raw} class="text-[28px] md:text-[42px] font-[800] tracking-[-0.02em] text-[#0a0a0b] leading-none">{s.value}</div>
          <div class="mt-[10px] font-mono text-[11px] tracking-[0.07em] text-[#8a8d93] uppercase">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  {/* Leaflet — self-hosted */}
  <link rel="stylesheet" href={`/js/lib/leaflet.css?v=${VERSION}`} />

  {/* Leaflet overrides */}
  <style is:global>
    [data-contributor-map] .leaflet-container { font-family: inherit; }
    [data-contributor-map] .leaflet-control-attribution { font-size: 9px; }
  </style>

  <script is:inline src={`/js/lib/leaflet.js?v=${VERSION}`}></script>
  <script src="../scripts/contributor-map.ts"></script>
  <script src="../scripts/count-up.ts"></script>
</Base>
