---
interface Props {
  title?: string;
}

const { title = "LexBlog Library" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="font-sans bg-white text-primary min-h-screen flex flex-col">
    <header class="bg-[#0a0a0b] text-white">
      <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight">LexBlog Library</a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/about" class="hover:text-gray-300 transition-colors">About</a>
          <a href="/submit" class="hover:text-gray-300 transition-colors">Submit Your Publishing</a>
          <a href="/author-record" class="hover:text-gray-300 transition-colors">Author Record</a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-[#0a0a0b] text-white text-sm">
      <div class="max-w-7xl mx-auto px-6 py-8 flex items-center justify-between">
        <p class="text-gray-400">&copy; {new Date().getFullYear()} LexBlog, Inc.</p>
        <div class="flex items-center gap-6 text-gray-400">
          <a href="https://www.lexblog.com" class="hover:text-white transition-colors">LexBlog.com</a>
        </div>
      </div>
    </footer>
  </body>
</html>
