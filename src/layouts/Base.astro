---
import SEO from "../components/SEO.astro";

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}

const {
  title = "LexBlog Library",
  description = "Preserving and structuring the insight of legal professionals as citable secondary law.",
  currentPage = "",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <SEO title={title} description={description} />
  </head>
  <body class="font-sans bg-white text-primary min-h-screen flex flex-col">
    <header data-site-header class="bg-[#0a0a0b] text-white w-full relative z-[1000]">
      {/* Primary nav */}
      <div class="max-w-[1240px] mx-auto px-5 md:px-8 h-[58px] md:h-[74px] flex items-center gap-8">
        <a href="/" class="flex items-baseline gap-2 md:gap-[11px] no-underline whitespace-nowrap">
          <span class="font-[800] text-[21px] md:text-[27px] tracking-tight text-white leading-none">LexBlog</span>
          <span class="font-normal text-[16px] md:text-[20px] tracking-tight text-white/[0.58] leading-none">Library</span>
        </a>

        {/* Desktop nav */}
        <nav class="hidden md:flex items-center gap-[30px] ml-auto whitespace-nowrap">
          <a
            href="/about"
            class:list={[
              "no-underline text-[15px] cursor-pointer transition-colors hover:text-white",
              currentPage === "about" ? "font-semibold text-white border-b-2 border-white pb-[3px]" : "font-medium text-white/[0.82]"
            ]}
          >About</a>
          <a
            href="/submit"
            class:list={[
              "no-underline text-[15px] cursor-pointer transition-colors hover:text-white",
              currentPage === "submit" || currentPage === "thank-you" ? "font-semibold text-white border-b-2 border-white pb-[3px]" : "font-medium text-white/[0.82]"
            ]}
          >Submit Your Publishing</a>
          <a
            href="/author-record"
            class:list={[
              "no-underline text-[15px] cursor-pointer transition-colors hover:text-white",
              currentPage === "author-record" ? "font-semibold text-white border-b-2 border-white pb-[3px]" : "font-medium text-white/[0.82]"
            ]}
          >Author Record</a>
        </nav>

        {/* Hamburger / X toggle */}
        <button
          data-mobile-menu-toggle
          class="md:hidden ml-auto relative w-6 h-6 flex items-center justify-center"
          aria-label="Toggle menu"
        >
          <svg data-icon-hamburger class="w-6 h-6 absolute inset-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg data-icon-close class="w-6 h-6 absolute inset-0 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      {/* Divider */}
      <div class="h-px bg-white/10"></div>

      {/* Secondary nav — desktop only */}
      <nav class="hidden md:flex max-w-[1240px] mx-auto px-8 h-12 items-stretch gap-[34px]">
        <a
          href="/"
          class="flex items-center no-underline text-[14.5px] font-semibold tracking-tight text-white border-b-2 border-white -mb-px"
        >Library</a>
        <a
          href="https://www.lexblog.com"
          class="flex items-center no-underline text-[14.5px] font-medium tracking-tight text-white/[0.72] border-b-2 border-transparent hover:text-white transition-colors"
        >Publishing Platform</a>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="text-[13px] text-[#6b7280]">
      <div class="max-w-[1240px] mx-auto px-5 md:px-8 py-6">
        Copyright &copy; 2026, LexBlog, Inc. All Rights Reserved.
      </div>
    </footer>

    {/* Mobile overlay menu — end of body for z-index */}
    <div
      data-mobile-menu
      class="fixed inset-0 top-[58px] bg-[#0a0a0b] z-[1001] hidden flex-col md:hidden"
    >
      <nav class="flex flex-col px-6 pt-6 gap-1">
        <a
          href="/"
          class:list={[
            "py-3 text-[17px] no-underline border-b border-white/10",
            currentPage === "home" || currentPage === "" ? "text-white font-semibold" : "text-white/80 font-medium"
          ]}
        >Library</a>
        <a
          href="/about"
          class:list={[
            "py-3 text-[17px] no-underline border-b border-white/10",
            currentPage === "about" ? "text-white font-semibold" : "text-white/80 font-medium"
          ]}
        >About</a>
        <a
          href="/submit"
          class:list={[
            "py-3 text-[17px] no-underline border-b border-white/10",
            currentPage === "submit" || currentPage === "thank-you" ? "text-white font-semibold" : "text-white/80 font-medium"
          ]}
        >Submit Your Publishing</a>
        <a
          href="/author-record"
          class:list={[
            "py-3 text-[17px] no-underline border-b border-white/10",
            currentPage === "author-record" ? "text-white font-semibold" : "text-white/80 font-medium"
          ]}
        >Author Record</a>
      </nav>
      <div class="mt-auto px-6 py-6 border-t border-white/10">
        <a
          href="https://www.lexblog.com"
          class="text-[14px] text-white/60 no-underline font-medium"
        >Publishing Platform &rarr;</a>
      </div>
    </div>

    <script src="../scripts/mobile-menu.ts"></script>
  </body>
</html>
